local queueTeleport = queue_on_teleport or (syn and syn.queue_on_teleport) or (fluxus and fluxus.queue_on_teleport)

local function ForceQueueScript()
	if queueTeleport then
		pcall(function()
			queueTeleport([[
				local name = "voidrush_spectator_cache.lua"
				if readfile and pcall(function() return readfile(name) end) then
					local run = loadstring(readfile(name))
					if run then task.spawn(run) end
				end
			]])
		end)
	end
end

