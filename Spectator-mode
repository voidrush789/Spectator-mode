--------------------------------------------------------------------------
-- MOBILE TOUCH PANNING & GESTURE CALCULATIONS
--------------------------------------------------------------------------

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if not freecamming then return end
	if input.UserInputType == Enum.UserInputType.Touch then
		if input.Position.X < (camera.ViewportSize.X * 0.4) then return end
		if gameProcessed then return end
		
		activeTouches[input] = true
		local touches = {}
		for t in pairs(activeTouches) do table.insert(touches, t) end
		
		if #touches == 2 and pinchZoomEnabled then
			panTouch = nil
			lastTouchPosition = nil
			initialPinchDistance = (Vector2.new(touches[1].Position.X, touches[1].Position.Y) - Vector2.new(touches[2].Position.X, touches[2].Position.Y)).Magnitude
		elseif #touches == 1 then
			panTouch = input
			lastTouchPosition = Vector2.new(input.Position.X, input.Position.Y)
		end
	end
end)

UserInputService.InputChanged:Connect(function(input, gameProcessed)
	if not freecamming then return end
	if not activeTouches[input] then return end
	
	local touches = {}
	for t in pairs(activeTouches) do table.insert(touches, t) end
	
	if #touches == 2 and initialPinchDistance and pinchZoomEnabled then
		local currentDistance = (Vector2.new(touches[1].Position.X, touches[1].Position.Y) - Vector2.new(touches[2].Position.X, touches[2].Position.Y)).Magnitude
		local change = currentDistance - initialPinchDistance
		initialPinchDistance = currentDistance
		
		local zoomSensitivity = 0.15
		camera.CFrame = camera.CFrame * CFrame.new(0, 0, -change * zoomSensitivity)
	elseif input == panTouch and lastTouchPosition then
		local currentPosition = Vector2.new(input.Position.X, input.Position.Y)
		local delta = currentPosition - lastTouchPosition
		lastTouchPosition = currentPosition
		
		cameraRotY = cameraRotY - (delta.X * 0.3)
		cameraRotX = cameraRotX - (delta.Y * 0.3)
		cameraRotX = math.clamp(cameraRotX, -85, 85)
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if activeTouches[input] then
		activeTouches[input] = nil
		initialPinchDistance = nil
	end
	if input == panTouch then
		panTouch = nil
		lastTouchPosition = nil
	end
end)

--------------------------------------------------------------------------
-- FREECAM STATE SWITCH ENGINE (LAYOUT MANIPULATION)
--------------------------------------------------------------------------

local function ToggleFreecam(state)
	local character = localPlayer.Character
	local hrp = character and character:FindFirstChild("HumanoidRootPart")

	if state then
		freecamming = true
		FreecamBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 100)
		
		-- Wipe all Server layouts instantly
		SSBtn.Visible = false
		CSBtn.Visible = false
		IDTextBox.Visible = false
		ApplyBtn.Visible = false
		
		-- Show Freecam layout settings
		ZoomBtn.Visible = true
		ShopBtn.Visible = true
		RJBtn.Visible = true
		
		local startingCFrame = camera.CFrame
		camera.CameraType = Enum.CameraType.Scriptable
		camera.CFrame = startingCFrame
		
		if hrp then hrp.Anchored = true end
		
		local look = startingCFrame.LookVector
		cameraRotY = math.deg(math.atan2(-look.X, -look.Z))
		cameraRotX = math.deg(math.asin(look.Y))
		
		freecamConnection = RunService.RenderStepped:Connect(function(dt)
			local moveVector = Vector3.new(0, 0, 0)
			if controls and controls.GetMoveVector then
				moveVector = controls:GetMoveVector()
			end
			
			local direction = (camera.CFrame.LookVector * -moveVector.Z) + (camera.CFrame.RightVector * moveVector.X)
			local targetPos = camera.CFrame.Position + (direction * moveSpeed * dt)
			camera.CFrame = CFrame.new(targetPos) * CFrame.Angles(0, math.rad(cameraRotY), 0) * CFrame.Angles(math.rad(cameraRotX), 0, 0)
		end)
	else
		freecamming = false
		FreecamBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
		
		-- Wipe Freecam layout items
		ZoomBtn.Visible = false
		ShopBtn.Visible = false
		RJBtn.Visible = false
		
		-- Safe restoration of SS button
		SSBtn.Visible = true
		if ssActive then
			CSBtn.Visible = true
			IDTextBox.Visible = true
			ApplyBtn.Visible = true
		end
		
		if freecamConnection then
			freecamConnection:Disconnect()
			freecamConnection = nil
		end
		
		if hrp then hrp.Anchored = false end
		camera.CameraType = Enum.CameraType.Custom
		
		if spectating and isViewingTarget and targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChildOfClass("Humanoid") then
			camera.CameraSubject = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
		else
			if character and character:FindFirstChildOfClass("Humanoid") then
				camera.CameraSubject = character:FindFirstChildOfClass("Humanoid")
			end
		end
	end
end

