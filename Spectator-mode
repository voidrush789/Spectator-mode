-- SMART TARGET PARSER (FIXES CROSS-GAME JOIN BUG)
--------------------------------------------------------------------------
local function parseTarget(inputText)
	local cleanText = inputText:match("^%s*(.-)%s*$") or ""
	local customPlaceId, customJobId = cleanText:match("^(%d+)[%s%c%p]+([%w%-]+)$")
	if customPlaceId and customJobId then
		return tonumber(customPlaceId), customJobId
	end
	return game.PlaceId, cleanText:gsub("%s+", "")
end

