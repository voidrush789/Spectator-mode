--------------------------------------------------------------------------
-- SYSTEM FUNCTIONAL LOGIC
--------------------------------------------------------------------------

local function GetPlayersList()
	local list = {}
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= localPlayer then table.insert(list, p) end
	end
	return list
end

local function UpdateSpectateTarget()
	local list = GetPlayersList()
	if #list == 0 then
		UserLabel.Text = "No Targets"
		NickLabel.Text = "Server Empty"
		ProfileIcon.Image = "rbxassetid://6075196476"
		camera.CameraSubject = localPlayer.Character and localPlayer.Character:FindFirstChildOfClass("Humanoid")
		return
	end

	if targetIndex > #list then targetIndex = 1 end
	if targetIndex < 1 then targetIndex = #list end

	targetPlayer = list[targetIndex]
	if targetPlayer then
		UserLabel.Text = targetPlayer.Name
		NickLabel.Text = targetPlayer.DisplayName
		
		task.spawn(function()
			local success, content = pcall(function()
				return Players:GetUserThumbnailAsync(targetPlayer.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size48x48)
			end)
			if success then ProfileIcon.Image = content else ProfileIcon.Image = "rbxassetid://6075196476" end
		end)

		if targetPlayer.Character and targetPlayer.Character:FindFirstChildOfClass("Humanoid") then
			camera.CameraSubject = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
		end
	end
end

task.spawn(function()
	while task.wait(0.2) do
		if spectating and targetPlayer then
			if targetPlayer.Character and targetPlayer.Character:FindFirstChildOfClass("Humanoid") then
				if camera.CameraSubject ~= targetPlayer.Character:FindFirstChildOfClass("Humanoid") then
					camera.CameraSubject = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
				end
			end
		end
	end
end)

LeftBtn.MouseButton1Click:Connect(function()
	targetIndex = targetIndex - 1
	UpdateSpectateTarget()
end)

RightBtn.MouseButton1Click:Connect(function()
	targetIndex = targetIndex + 1
	UpdateSpectateTarget()
end)

--------------------------------------------------------------------------
-- SECURE INTERCEPT CHAT TOGGLE LOGIC (INVISIBLE TO OTHERS)
--------------------------------------------------------------------------
local function ToggleSpectate()
	spectating = not spectating
	if spectating then
		ControlFrame.Visible = true
		targetIndex = 1
		UpdateSpectateTarget()
	else
		ControlFrame.Visible = false
		targetPlayer = nil
		if localPlayer.Character and localPlayer.Character:FindFirstChildOfClass("Humanoid") then
			camera.CameraSubject = localPlayer.Character:FindFirstChildOfClass("Humanoid")
		end
	end
end

-- 1. Modern Chat Interceptor (Completely blocks messages from going to server)
if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
	local textCommands = TextChatService:FindFirstChild("TextCommands") or TextChatService:WaitForChild("TextCommands", 5)
	if textCommands then
		-- Clean up any existing duplicate registered commands
		local oldCmd = textCommands:FindFirstChild("VoidViewCommand")
		if oldCmd then oldCmd:Destroy() end

		local viewCommand = Instance.new("TextChatCommand")
		viewCommand.Name = "VoidViewCommand"
		viewCommand.PrimaryAlias = "/view"
		viewCommand.SecondaryAlias = "/View"
		viewCommand.Parent = textCommands
		
		viewCommand.Triggered:Connect(function()
			ToggleSpectate()
		end)
	end
end

-- 2. Legacy Chat Fallback Hook (Just in case the place rolls back versions)
localPlayer.Chatted:Connect(function(msg)
	if TextChatService.ChatVersion == Enum.ChatVersion.LegacyChatService then
		if msg:lower() == "/view" then
			ToggleSpectate()
		end
	end
end)
