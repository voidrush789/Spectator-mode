-- SYSTEM FUNCTIONAL LOGIC
--------------------------------------------------------------------------

local function GetPlayersList()
	local list = {}
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= localPlayer then table.insert(list, p) end
	end
	return list
end

-- Safely updates UI names and handles character streaming avatar requests
local function UpdateSpectateTarget()
	local list = GetPlayersList()
	if #list == 0 then
		UserLabel.Text = "No Targets"
		NickLabel.Text = "Server Empty"
		ProfileIcon.Image = "rbxassetid://6075196476"
		camera.CameraSubject = localPlayer.Character and localPlayer.Character:FindFirstChildOfClass("Humanoid")
		return
	end

	if targetIndex > #list then targetIndex = 1 end
	if targetIndex < 1 then targetIndex = #list end

	targetPlayer = list[targetIndex]
	if targetPlayer then
		UserLabel.Text = targetPlayer.Name
		NickLabel.Text = targetPlayer.DisplayName
		
		-- Fetch the player's real avatar headshot thumbnail instantly
		task.spawn(function()
			local success, content = pcall(function()
				return Players:GetUserThumbnailAsync(targetPlayer.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size48x48)
			end)
			if success then
				ProfileIcon.Image = content
			else
				ProfileIcon.Image = "rbxassetid://6075196476"
			end
		end)

		if targetPlayer.Character and targetPlayer.Character:FindFirstChildOfClass("Humanoid") then
			camera.CameraSubject = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
		end
	end
end

-- Keeps focus anchored even through deaths or respawns
task.spawn(function()
	while task.wait(0.2) do
		if spectating and targetPlayer then
			if targetPlayer.Character and targetPlayer.Character:FindFirstChildOfClass("Humanoid") then
				if camera.CameraSubject ~= targetPlayer.Character:FindFirstChildOfClass("Humanoid") then
					camera.CameraSubject = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
				end
			end
		end
	end
end)

-- Arrow Connections
LeftBtn.MouseButton1Click:Connect(function()
	targetIndex = targetIndex - 1
	UpdateSpectateTarget()
end)

RightBtn.MouseButton1Click:Connect(function()
	targetIndex = targetIndex + 1
	UpdateSpectateTarget()
end)

